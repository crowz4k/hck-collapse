{
  "manifest_version": 3,
  "name": "HN Collapse All Comments",
  "version": "1.0",
  "description": "Collapse all comments on Hacker News story pages",
  "permissions": ["activeTab", "scripting"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Collapse all HN comments"
  },
  "background": {
    "service_worker": "background.js"
  }
}
